{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "pinbase/theme.schema.json",
  "title": "Pinbase Theme",
  "description": "Frontmatter for a Pinbase-authored theme record",
  "type": "object",
  "properties": {
    "name": { "type": "string", "minLength": 1, "pattern": "^[^\\uFFFD]*$" },
    "aliases": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "minItems": 1
    },
    "parents": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "minItems": 1
    }
  },
  "required": ["name"],
  "additionalProperties": false
}
