{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "pinbase/location_country.schema.json",
  "title": "Pinbase Location Country",
  "description": "Frontmatter for a country-level location record",
  "type": "object",
  "properties": {
    "name": { "type": "string", "minLength": 1 },
    "aliases": {
      "type": "array",
      "description": "Alternate names and known variants (e.g. England, Britain, UK for United Kingdom; West Germany for Germany)",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true,
      "default": []
    },
    "divisions": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["city", "country", "county", "department", "district", "prefecture", "province", "region", "state"]
      },
      "minItems": 1
    }
  },
  "required": ["name", "divisions"],
  "additionalProperties": false
}
