{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "pinbase/corporate_entity.schema.json",
  "title": "Pinbase Corporate Entity",
  "description": "Frontmatter for a Pinbase-authored corporate entity record",
  "type": "object",
  "properties": {
    "name": { "type": "string", "minLength": 1 },
    "aliases": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true,
      "default": []
    },
    "manufacturer_slug": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "ipdb_manufacturer_id": { "type": ["integer", "null"] },
    "year_start": { "type": ["integer", "null"] },
    "year_end": { "type": ["integer", "null"] },
    "headquarters_city": { "type": ["string", "null"] },
    "headquarters_state": { "type": ["string", "null"] },
    "headquarters_country": { "type": ["string", "null"] }
  },
  "required": ["name", "manufacturer_slug"],
  "additionalProperties": false
}
