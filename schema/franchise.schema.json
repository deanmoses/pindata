{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "pinbase/franchise.schema.json",
  "title": "Pinbase Franchise",
  "description": "Frontmatter for a Pinbase-authored franchise record",
  "type": "object",
  "properties": {
    "name": { "type": "string", "minLength": 1, "pattern": "^[^\\uFFFD]*$" }
  },
  "required": ["name"],
  "additionalProperties": false
}
