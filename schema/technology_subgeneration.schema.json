{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "pinbase/technology_subgeneration.schema.json",
  "title": "Pinbase Technology Subgeneration",
  "description": "Frontmatter for a Pinbase-authored technology subgeneration record",
  "type": "object",
  "properties": {
    "name": { "type": "string", "minLength": 1 },
    "display_order": { "type": "integer", "minimum": 0 },
    "technology_generation_slug": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    }
  },
  "required": ["name", "display_order", "technology_generation_slug"],
  "additionalProperties": false
}
